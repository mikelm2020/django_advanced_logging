# ============================================================================
# ENVIRONMENT VARIABLES - LOCAL DEVELOPMENT
# ============================================================================
# Este archivo contiene las variables de entorno para desarrollo local.
# Copia este archivo a .env y ajusta los valores según tu configuración.
#
# Uso: cp .env.local.example .env
# ============================================================================

# Django Settings
# ============================================================================
DJANGO_SETTINGS_MODULE=myproject.settings.local
DEBUG=True
SECRET_KEY=your-secret-key-for-local-development-change-this
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration (PostgreSQL)
# ============================================================================
# El paquete django-advanced-logging usa la MISMA base de datos de Django
DB_ENGINE=django.db.backends.postgresql
DB_NAME=myproject_local
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Logging Configuration
# ============================================================================
# Configuración para django-advanced-logging
LOG_NAME=myproject_local
LOG_LEVEL=DEBUG
LOG_ENVIRONMENT=development
LOG_CONSOLE=true
LOG_FILE=false
LOG_JSON=false

# PostgreSQL Logging (usa la misma BD de Django)
# ============================================================================
POSTGRES_ENABLED=true
LOG_DB_TABLE=application_logs
LOG_BUFFER_SIZE=1000
LOG_BATCH_SIZE=10
LOG_FLUSH_INTERVAL=5.0

# Optional: Si quieres usar una BD diferente para logs (NO recomendado)
# Descomenta estas líneas SOLO si necesitas una BD separada
# LOG_DB_HOST=localhost
# LOG_DB_PORT=5432
# LOG_DB_NAME=logs_db
# LOG_DB_USER=postgres
# LOG_DB_PASSWORD=postgres

# Docker Configuration
# ============================================================================
COMPOSE_FILE=docker-compose.yml:docker-compose.override.local.yml
COMPOSE_PROJECT_NAME=myproject_local

# Python/Poetry Configuration
# ============================================================================
POETRY_VIRTUALENVS_CREATE=false
POETRY_NO_INTERACTION=1
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Optional Services
# ============================================================================
# Redis (si lo usas)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Email (desarrollo)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
