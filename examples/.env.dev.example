# ============================================================================
# ENVIRONMENT VARIABLES - DEVELOPMENT (CI/CD)
# ============================================================================
# Este archivo contiene las variables de entorno para el ambiente de desarrollo
# en servidores CI/CD o ambientes de desarrollo compartidos.
#
# Uso: cp .env.dev.example .env.dev
# ============================================================================

# Django Settings
# ============================================================================
DJANGO_SETTINGS_MODULE=myproject.settings.development
DEBUG=False
SECRET_KEY=${SECRET_KEY}  # Debe ser provisto por CI/CD o secrets manager
ALLOWED_HOSTS=dev.myproject.com,*.dev.myproject.com

# Database Configuration (PostgreSQL)
# ============================================================================
# El paquete django-advanced-logging usa la MISMA base de datos de Django
DB_ENGINE=django.db.backends.postgresql
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_HOST=${DB_HOST}
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Logging Configuration
# ============================================================================
# Configuración para django-advanced-logging
LOG_NAME=myproject_dev
LOG_LEVEL=DEBUG
LOG_ENVIRONMENT=development
LOG_CONSOLE=true
LOG_FILE=true
LOG_JSON=true

# PostgreSQL Logging (usa la misma BD de Django)
# ============================================================================
POSTGRES_ENABLED=true
LOG_DB_TABLE=application_logs
LOG_BUFFER_SIZE=2000
LOG_BATCH_SIZE=20
LOG_FLUSH_INTERVAL=3.0

# Docker Configuration
# ============================================================================
COMPOSE_FILE=docker-compose.yml:docker-compose.override.dev.yml
COMPOSE_PROJECT_NAME=myproject_dev

# Python/Poetry Configuration
# ============================================================================
POETRY_VIRTUALENVS_CREATE=false
POETRY_NO_INTERACTION=1
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Cache Configuration (Redis)
# ============================================================================
REDIS_URL=${REDIS_URL}
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=${REDIS_URL}
CACHE_DEFAULT_TIMEOUT=300

# Celery Configuration
# ============================================================================
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_ALWAYS_EAGER=False

# Email Configuration
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=${EMAIL_HOST}
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=${EMAIL_HOST_USER}
EMAIL_HOST_PASSWORD=${EMAIL_HOST_PASSWORD}
DEFAULT_FROM_EMAIL=noreply@myproject.com

# Monitoring & Performance
# ============================================================================
# Sentry (opcional)
SENTRY_DSN=${SENTRY_DSN}
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.5

# New Relic (opcional)
NEW_RELIC_LICENSE_KEY=${NEW_RELIC_LICENSE_KEY}
NEW_RELIC_APP_NAME=myproject-dev
NEW_RELIC_ENVIRONMENT=development

# Security
# ============================================================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
