# Ejemplo de pyproject.toml para un proyecto Django que usa django-advanced-logging
#
# Copia este archivo a tu proyecto Django y renómbralo a pyproject.toml
# Luego ejecuta: poetry install

[tool.poetry]
name = "mi-proyecto-django"
version = "1.0.0"
description = "Mi proyecto Django con django-advanced-logging"
authors = ["Tu Nombre <tu.email@example.com>"]
readme = "README.md"

[tool.poetry.dependencies]
python = "^3.10"
Django = "^4.0.2"

# ============================================================================
# INSTALACIÓN DE DJANGO-ADVANCED-LOGGING
# ============================================================================

# --- OPCIÓN 1: Instalación Local (Desarrollo/Pruebas) ---
# Usa esta opción cuando estés probando el paquete en tu máquina local
# El parámetro 'develop = true' permite que los cambios se reflejen inmediatamente

django-advanced-logging = {path = "../django-advanced-logging", develop = true}

# --- OPCIÓN 2: Instalación desde Git (Equipo/Staging/Producción) ---
# Usa esta opción una vez que el paquete esté en Git y quieras compartirlo con el equipo

# Opción 2a: Última versión de la rama main
# django-advanced-logging = {git = "https://github.com/tu-empresa/django-advanced-logging.git"}

# Opción 2b: Versión específica con tag (RECOMENDADO para producción)
# django-advanced-logging = {git = "https://github.com/tu-empresa/django-advanced-logging.git", tag = "v1.0.0"}

# Opción 2c: Rama específica
# django-advanced-logging = {git = "https://github.com/tu-empresa/django-advanced-logging.git", branch = "develop"}

# Opción 2d: Commit específico
# django-advanced-logging = {git = "https://github.com/tu-empresa/django-advanced-logging.git", rev = "abc123"}

# ============================================================================
# POSTGRESQL - Requerido para django-advanced-logging
# ============================================================================

# Elige UNA de las siguientes opciones según tu configuración:

# Opción A: psycopg3 (recomendado para proyectos nuevos)
psycopg = {extras = ["binary"], version = "^3.1.0"}

# Opción B: psycopg2-binary (para proyectos existentes con psycopg2)
# psycopg2-binary = "^2.9.0"

# ============================================================================
# OTRAS DEPENDENCIAS DE TU PROYECTO
# ============================================================================

# API & Serialización
djangorestframework = "^3.14.0"
django-cors-headers = "^4.0.0"

# Base de datos
dj-database-url = "^2.0.0"  # Para DATABASE_URL en Docker

# Servidor de aplicación
gunicorn = "^21.0.0"

# Utilidades
python-dotenv = "^1.0.0"
pillow = "^10.0.0"  # Si usas ImageField

# Celery (opcional)
# celery = "^5.3.0"
# redis = "^4.5.0"

[tool.poetry.group.dev.dependencies]
# Herramientas de desarrollo
pytest = "^7.4.0"
pytest-django = "^4.5.0"
pytest-cov = "^4.1.0"
black = "^23.7.0"
flake8 = "^6.0.0"
isort = "^5.12.0"
mypy = "^1.4.0"
django-stubs = "^4.2.0"
ipython = "^8.14.0"
django-debug-toolbar = "^4.1.0"

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"

# ============================================================================
# CONFIGURACIÓN DE PYTEST
# ============================================================================

[tool.pytest.ini_options]
DJANGO_SETTINGS_MODULE = "config.settings.test"
python_files = ["test_*.py", "*_test.py"]
python_classes = ["Test*"]
python_functions = ["test_*"]
addopts = "--reuse-db --cov=. --cov-report=html --cov-report=term-missing"
testpaths = ["tests"]

# ============================================================================
# CONFIGURACIÓN DE BLACK
# ============================================================================

[tool.black]
line-length = 100
target-version = ['py310']
include = '\.pyi?$'
exclude = '''
/(
    \.git
  | \.hg
  | \.mypy_cache
  | \.tox
  | \.venv
  | _build
  | buck-out
  | build
  | dist
  | migrations
)/
'''

# ============================================================================
# CONFIGURACIÓN DE ISORT
# ============================================================================

[tool.isort]
profile = "black"
line_length = 100
multi_line_output = 3
include_trailing_comma = true
force_grid_wrap = 0
use_parentheses = true
ensure_newline_before_comments = true
skip_gitignore = true
skip = ["migrations", ".venv", "venv"]

# ============================================================================
# CONFIGURACIÓN DE MYPY
# ============================================================================

[tool.mypy]
python_version = "3.10"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = false
ignore_missing_imports = true
plugins = ["mypy_django_plugin.main"]

[tool.django-stubs]
django_settings_module = "config.settings.local"

# ============================================================================
# COMANDOS ÚTILES
# ============================================================================

# Instalación:
#   poetry install                    # Instalar todas las dependencias
#   poetry install --no-dev          # Solo dependencias de producción
#   poetry install --with dev        # Con dependencias de desarrollo

# Actualizar django-advanced-logging:
#   poetry update django-advanced-logging

# Agregar nueva dependencia:
#   poetry add nombre-paquete

# Entrar al shell de Poetry:
#   poetry shell

# Ejecutar comandos:
#   poetry run python manage.py migrate
#   poetry run python manage.py runserver
#   poetry run pytest

# Lock dependencies (generar poetry.lock):
#   poetry lock

# Exportar requirements.txt (si lo necesitas):
#   poetry export -f requirements.txt --output requirements.txt --without-hashes
