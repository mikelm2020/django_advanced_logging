# ============================================================================
# ENVIRONMENT VARIABLES - STAGING
# ============================================================================
# Este archivo contiene las variables de entorno para el ambiente de staging.
# Este ambiente debe replicar producción lo más fielmente posible.
#
# Uso: Proveer estas variables a través de secrets manager o CI/CD
# ============================================================================

# Django Settings
# ============================================================================
DJANGO_SETTINGS_MODULE=myproject.settings.staging
DEBUG=False
SECRET_KEY=${SECRET_KEY}  # REQUERIDO: Debe ser provisto por secrets manager
ALLOWED_HOSTS=staging.myproject.com,*.staging.myproject.com

# Database Configuration (PostgreSQL)
# ============================================================================
# El paquete django-advanced-logging usa la MISMA base de datos de Django
DB_ENGINE=django.db.backends.postgresql
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_HOST=${DB_HOST}
DB_PORT=5432
DB_CONN_MAX_AGE=600
DB_SSL_MODE=require

# Logging Configuration
# ============================================================================
# Configuración para django-advanced-logging
LOG_NAME=myproject_staging
LOG_LEVEL=INFO
LOG_ENVIRONMENT=staging
LOG_CONSOLE=true
LOG_FILE=true
LOG_JSON=true

# PostgreSQL Logging (usa la misma BD de Django)
# ============================================================================
POSTGRES_ENABLED=true
LOG_DB_TABLE=application_logs
LOG_BUFFER_SIZE=5000
LOG_BATCH_SIZE=50
LOG_FLUSH_INTERVAL=2.0

# Docker Configuration
# ============================================================================
COMPOSE_FILE=docker-compose.yml:docker-compose.override.staging.yml
COMPOSE_PROJECT_NAME=myproject_staging

# Python/Poetry Configuration
# ============================================================================
POETRY_VIRTUALENVS_CREATE=false
POETRY_NO_INTERACTION=1
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Cache Configuration (Redis)
# ============================================================================
REDIS_URL=${REDIS_URL}
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=${REDIS_URL}
CACHE_DEFAULT_TIMEOUT=600
REDIS_MAX_CONNECTIONS=50

# Celery Configuration
# ============================================================================
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_ALWAYS_EAGER=False
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# Email Configuration
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=${EMAIL_HOST}
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=${EMAIL_HOST_USER}
EMAIL_HOST_PASSWORD=${EMAIL_HOST_PASSWORD}
DEFAULT_FROM_EMAIL=noreply@myproject.com
SERVER_EMAIL=server@myproject.com

# Monitoring & Performance
# ============================================================================
# Sentry
SENTRY_DSN=${SENTRY_DSN}
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.3
SENTRY_PROFILES_SAMPLE_RATE=0.1

# New Relic (opcional)
NEW_RELIC_LICENSE_KEY=${NEW_RELIC_LICENSE_KEY}
NEW_RELIC_APP_NAME=myproject-staging
NEW_RELIC_ENVIRONMENT=staging
NEW_RELIC_MONITOR_MODE=true

# Security
# ============================================================================
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True
X_FRAME_OPTIONS=DENY

# CORS (si aplica)
# ============================================================================
CORS_ALLOWED_ORIGINS=https://staging.myproject.com
CORS_ALLOW_CREDENTIALS=True

# Static & Media Files (S3 o similar)
# ============================================================================
USE_S3=True
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_STORAGE_BUCKET_NAME=${AWS_STORAGE_BUCKET_NAME}
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=${AWS_S3_CUSTOM_DOMAIN}

# Health Checks
# ============================================================================
HEALTH_CHECK_ENABLED=True
HEALTH_CHECK_DATABASE=True
HEALTH_CHECK_CACHE=True
