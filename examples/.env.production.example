# ============================================================================
# ENVIRONMENT VARIABLES - PRODUCTION
# ============================================================================
# Este archivo contiene las variables de entorno para el ambiente de producción.
# IMPORTANTE: Usar secrets manager (AWS Secrets Manager, Vault, etc.)
#
# NUNCA commitear este archivo con valores reales.
# ============================================================================

# Django Settings
# ============================================================================
DJANGO_SETTINGS_MODULE=myproject.settings.production
DEBUG=False
SECRET_KEY=${SECRET_KEY}  # CRÍTICO: Debe ser provisto por secrets manager
ALLOWED_HOSTS=myproject.com,www.myproject.com,api.myproject.com

# Database Configuration (PostgreSQL)
# ============================================================================
# El paquete django-advanced-logging usa la MISMA base de datos de Django
DB_ENGINE=django.db.backends.postgresql
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_HOST=${DB_HOST}
DB_PORT=5432
DB_CONN_MAX_AGE=600
DB_SSL_MODE=require

# Database Read Replicas (opcional)
# ============================================================================
DB_READ_REPLICA_HOST=${DB_READ_REPLICA_HOST}
DB_READ_REPLICA_PORT=5432

# Logging Configuration
# ============================================================================
# Configuración para django-advanced-logging
LOG_NAME=myproject_prod
LOG_LEVEL=WARNING
LOG_ENVIRONMENT=production
LOG_CONSOLE=false
LOG_FILE=true
LOG_JSON=true

# PostgreSQL Logging (usa la misma BD de Django)
# ============================================================================
POSTGRES_ENABLED=true
LOG_DB_TABLE=application_logs
LOG_BUFFER_SIZE=10000
LOG_BATCH_SIZE=100
LOG_FLUSH_INTERVAL=1.0

# Docker Configuration
# ============================================================================
COMPOSE_FILE=docker-compose.yml:docker-compose.override.production.yml
COMPOSE_PROJECT_NAME=myproject_prod

# Python/Poetry Configuration
# ============================================================================
POETRY_VIRTUALENVS_CREATE=false
POETRY_NO_INTERACTION=1
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Cache Configuration (Redis)
# ============================================================================
REDIS_URL=${REDIS_URL}
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=${REDIS_URL}
CACHE_DEFAULT_TIMEOUT=3600
REDIS_MAX_CONNECTIONS=100

# Redis Sentinel (alta disponibilidad)
# ============================================================================
# REDIS_SENTINEL_HOSTS=${REDIS_SENTINEL_HOSTS}
# REDIS_SENTINEL_SERVICE_NAME=mymaster

# Celery Configuration
# ============================================================================
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_ALWAYS_EAGER=False
CELERY_WORKER_CONCURRENCY=8
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=900
CELERY_TASK_ACKS_LATE=True
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# Email Configuration
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=${EMAIL_HOST}
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=${EMAIL_HOST_USER}
EMAIL_HOST_PASSWORD=${EMAIL_HOST_PASSWORD}
DEFAULT_FROM_EMAIL=noreply@myproject.com
SERVER_EMAIL=server@myproject.com

# Monitoring & Performance
# ============================================================================
# Sentry (monitoreo de errores)
SENTRY_DSN=${SENTRY_DSN}
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05
SENTRY_SEND_DEFAULT_PII=False

# New Relic (APM)
NEW_RELIC_LICENSE_KEY=${NEW_RELIC_LICENSE_KEY}
NEW_RELIC_APP_NAME=myproject-production
NEW_RELIC_ENVIRONMENT=production
NEW_RELIC_MONITOR_MODE=true
NEW_RELIC_LOG_LEVEL=info

# Datadog (opcional)
# DD_API_KEY=${DD_API_KEY}
# DD_SITE=datadoghq.com
# DD_ENV=production
# DD_SERVICE=myproject
# DD_VERSION=${APP_VERSION}

# Security
# ============================================================================
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True
X_FRAME_OPTIONS=DENY

# Session Security
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict
SESSION_COOKIE_AGE=3600
SESSION_SAVE_EVERY_REQUEST=False

# CORS Configuration
# ============================================================================
CORS_ALLOWED_ORIGINS=https://myproject.com,https://www.myproject.com
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_HEADERS=accept,accept-encoding,authorization,content-type,dnt,origin,user-agent,x-csrftoken,x-requested-with

# Static & Media Files (S3 o CDN)
# ============================================================================
USE_S3=True
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_STORAGE_BUCKET_NAME=${AWS_STORAGE_BUCKET_NAME}
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=${AWS_S3_CUSTOM_DOMAIN}
AWS_S3_OBJECT_PARAMETERS_CACHE_CONTROL=max-age=86400

# CloudFront CDN (opcional)
CLOUDFRONT_DOMAIN=${CLOUDFRONT_DOMAIN}
CLOUDFRONT_KEY_PAIR_ID=${CLOUDFRONT_KEY_PAIR_ID}
CLOUDFRONT_PRIVATE_KEY=${CLOUDFRONT_PRIVATE_KEY}

# Rate Limiting
# ============================================================================
RATELIMIT_ENABLE=True
RATELIMIT_USE_CACHE=default
RATELIMIT_VIEW_DEFAULT=100/h

# Health Checks & Monitoring
# ============================================================================
HEALTH_CHECK_ENABLED=True
HEALTH_CHECK_DATABASE=True
HEALTH_CHECK_CACHE=True
HEALTH_CHECK_CELERY=True
HEALTH_CHECK_STORAGE=True

# Backup Configuration
# ============================================================================
BACKUP_ENABLED=True
BACKUP_S3_BUCKET=${BACKUP_S3_BUCKET}
BACKUP_RETENTION_DAYS=30

# Feature Flags (opcional)
# ============================================================================
# FEATURE_NEW_DASHBOARD=True
# FEATURE_BETA_API=False

# Application Version
# ============================================================================
APP_VERSION=${APP_VERSION}
GIT_COMMIT=${GIT_COMMIT}
BUILD_DATE=${BUILD_DATE}
